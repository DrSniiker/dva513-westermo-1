GOOSE_DATASET_PATH=/absolute/path/to/goose-preprocessed-csv-files

# Directory that contains:
# - UNSW_NB15_training-set.csv
# - UNSW_NB15_testing-set.csv
UNSW_DATASET_PATH=/absolute/path/to/unsw-archive
